<!-- Header -->
![header](https://capsule-render.vercel.app/api?type=<%= header.type %>&height=<%= header.height %>&color=<%= header.color %>&text=<%= encodeURIComponent(header.text) %>&section=header&reversal=false&desc=<%= header.rawDesc ? header.desc : encodeURIComponent(header.desc) %>&fontAlignY=<%= header.fontAlignY %>&descAlignY=<%= header.descAlignY %>&descSize=<%= header.descSize %>)

## <%= intro.title %>

<% for (const line of intro.lines) { %>
<%= line %>
<% } %>

<%= intro.currentFocus %>

📫 **Contact**: [Email](mailto:<%= contact.email %>) · [LinkedIn](<%= contact.linkedin %>) · [Blog](<%= contact.blog %>)

---

<!-- Tech Stack -->
<% for (const [groupName, items] of Object.entries(badges)) { %>
### **<%= groupName %>**
<% for (const b of items) { %>![<%= b.label %>](https://img.shields.io/badge/<%= encodeURIComponent(b.label) %>-<%= b.color %>.svg?&style=for-the-badge&logo=<%= b.logo %>&logoColor=white)
<% } %>

<% } %>
---

<!-- Career -->
![story](https://capsule-render.vercel.app/api?type=<%= storyBanner.type %>&height=<%= storyBanner.height %>&color=<%= storyBanner.color %>&text=<%= encodeURIComponent(storyBanner.text) %>&section=header&reversal=false&fontAlignY=55&fontColor=<%= storyBanner.fontColor %>&stroke=ffffff&strokeWidth=2)

### **Working**
- <%= career.working %>

### 🚀 Projects
<% for (const proj of career.projects) { %>

**<%= proj.period %>** | **<%= proj.title %>**
<% for (const d of proj.details) { %>
- <%= d %>
<% } %>
<% } %>
<% if (career.sideProjects && career.sideProjects.length > 0) { %>

### 🧪 Side Projects
<% for (const sp of career.sideProjects) { %>
- [**<%= sp.title %>**](<%= sp.url %>) (<%= sp.period %>) — <%= sp.desc %>
<% } %>
<% } %>

<details>
<summary><b>📖 History</b></summary>

<% for (const item of career.history) { %>
- <%= item %>
<% } %>
</details>
<% if (pinnedRepos.length > 0) { %>

### 📌 Pinned Repositories
<% for (const repo of pinnedRepos) { %>
- [**<%= repo.name %>**](<%= repo.url %>) — <%= repo.description %> ⭐ <%= repo.stars %>
<% } %>
<% } %>

---

<!-- Blog -->
![blog](https://capsule-render.vercel.app/api?type=<%= blogBanner.type %>&height=<%= blogBanner.height %>&color=<%= blogBanner.color %>&text=<%= encodeURIComponent(blogBanner.text) %>&fontSize=<%= blogBanner.fontSize %>&reversal=false)

<div align="center">
<% for (const post of blogPosts) { %>

#### [📝 <%= post.title %>](<%= post.link %>)</br>
<% } %>
</div>
